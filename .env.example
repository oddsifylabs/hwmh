# HWMH - Hermes Workers Management Hub
# Environment Variables

# Admin credentials
ADMIN_USERNAME=Joshua
ADMIN_PASSWORD=change_me_in_production

# API key for CLI / dashboard / worker authentication
# Generate: openssl rand -hex 32
API_KEY=your_random_key_here

# AI Engine
KIMI_API_KEY=sk-xxxxxxxxxxxx

# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Railway
RAILWAY_PROJECT_ID=your_project_id

# Telegram Bot Tokens
GOTTFRIED_BOT_TOKEN=***
SOPHIA_BOT_TOKEN=***
IRIS_BOT_TOKEN=***
PHEME_BOT_TOKEN=***
KAIROS_BOT_TOKEN=***

# Telegram Alert Pager (Mr. Jones Hermes)
TELEGRAM_ALERT_BOT_TOKEN=***
TELEGRAM_ALERT_CHAT_ID=8502906149

# Director name (displayed in Sophia's messages)
DIRECTOR_NAME=Director

# Gottfried verbose logging (true/false)
GOTTFRIED_VERBOSE=false

# Server port
PORT=3000

# 1Password Secrets Vault (optional but recommended)
# Set ONEPASSWORD_ENABLED=true to read secrets from 1Password instead of .env
ONEPASSWORD_ENABLED=false
ONEPASSWORD_VAULT=HWMH
ONEPASSWORD_SERVICE_ACCOUNT_TOKEN=ops_...

# Railway API Token (for deploy validator)
RAILWAY_TOKEN=
